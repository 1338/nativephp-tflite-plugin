{
  "name": "1338/nativephp-tflite",
  "description": "NativePHP plugin for TensorFlow Lite model storage, metadata, and inference",
  "type": "nativephp-plugin",
  "license": "MIT",
  "keywords": [
    "nativephp",
    "tensorflow-lite",
    "tflite",
    "android",
    "inference"
  ],
  "require": {
    "php": "^8.3",
    "nativephp/mobile": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "OneThreeThreeEight\\NativephpTflite\\": "src/"
    }
  },
  "extra": {
    "nativephp": {
      "manifest": "nativephp.json"
    },
    "laravel": {
      "providers": [
        "OneThreeThreeEight\\NativephpTflite\\TfliteServiceProvider"
      ]
    }
  }
}
